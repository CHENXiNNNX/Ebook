# Console on UART0 (U0TXD/U0RXD, typically GPIO43/44 on ESP32-S3 module).
# Use a USB-UART adapter on the breakout pins for idf.py flash monitor.
# Board USB port is reserved for future OTG / MSC (Transfer app).
CONFIG_ESP_CONSOLE_UART_DEFAULT=y
CONFIG_ESP_CONSOLE_UART_NUM=0
CONFIG_ESP_CONSOLE_UART_BAUDRATE=115200
CONFIG_ESPTOOLPY_MONITOR_BAUD=115200
CONFIG_ESP_CONSOLE_SECONDARY_NONE=y
CONFIG_USJ_ENABLE_USB_SERIAL_JTAG=n

# userdata USB MSC
CONFIG_TINYUSB_MSC_ENABLED=y
CONFIG_TINYUSB_MSC_BUFSIZE=8192
# The WL sector must be 4096; otherwise, it will result in the failure of the first startup mount and the erasure of the factory-installed content.
CONFIG_WL_SECTOR_SIZE_4096=y

CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y

# partition table
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions/partition_16mb.csv"
CONFIG_PARTITION_TABLE_OFFSET=0x8000

# cpu
CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_240=y

# psram
CONFIG_SPIRAM_XIP_FROM_PSRAM=y
CONFIG_ESP32S3_INSTRUCTION_CACHE_32KB=y
CONFIG_ESP32S3_DATA_CACHE_64KB=y
CONFIG_ESP32S3_DATA_CACHE_LINE_64B=y

# spiram (octal)
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_SPEED_80M=y
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=512
CONFIG_SPIRAM_MALLOC_RESERVE_INTERNAL=65536
CONFIG_SPIRAM_MEMTEST=n
CONFIG_MBEDTLS_EXTERNAL_MEM_ALLOC=y
