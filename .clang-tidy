# clang-tidy 配置（ESP-IDF / C+C++ 混编）
# 使用方式（示例）：
#   cmake -DCMAKE_EXPORT_COMPILE_COMMANDS=ON ... && ninja
#   clang-tidy -p build main/**/*.cc
# 若告警过多，可先缩小范围或注释掉 readability-identifier-naming 段。

# readability-redundant-member-init：关闭后与 cppcoreguidelines-pro-type-member-init 共存（如 vector servers_{}）

Checks: >
  -*,
  clang-analyzer-*,
  bugprone-*,
  -bugprone-easily-swappable-parameters,
  -bugprone-signal-handler,
  -bugprone-reserved-identifier,
  performance-*,
  -performance-enum-size,
  portability-*,
  -portability-avoid-pragma-once,
  readability-*,
  -readability-identifier-length,
  -readability-magic-numbers,
  -readability-function-cognitive-complexity,
  -readability-braces-around-statements,
  -readability-redundant-member-init,
  -readability-make-member-function-const,
  -readability-uppercase-literal-suffix,
  cppcoreguidelines-init-variables,
  cppcoreguidelines-pro-type-member-init,
  cppcoreguidelines-avoid-goto,
  cppcoreguidelines-prefer-member-init,
  modernize-avoid-bind,
  -modernize-use-nullptr,
  -modernize-use-default-member-init,
  modernize-redundant-void-arg,
  -modernize-use-trailing-return-type,
  cert-*,
  -cert-err58-cpp,
  -cert-dcl50-cpp

WarningsAsErrors: ""

# 只对「工程自有源码」报告问题，忽略第三方 / 生成代码（按路径微调）
HeaderFilterRegex: '.*/(main|components)/.*\\.(h|hpp)$'
ImplementationFileExtensions:
  - cc
  - cpp
  - cxx
  - c

ExtraArgsBefore:
  - -Wno-unknown-warning-option
  - -std=c++17

CheckOptions:
  # --- readability-identifier-naming（与当前 snake_case / PascalCase 约定对齐）---
  readability-identifier-naming.ClassCase: CamelCase
  readability-identifier-naming.StructCase: CamelCase
  readability-identifier-naming.UnionCase: CamelCase
  readability-identifier-naming.EnumCase: CamelCase
  # enum class 取值用 CamelCase（ReferHint::Auto）
  readability-identifier-naming.ScopedEnumConstantCase: CamelCase
  # 枚举取值沿用嵌入式常见全大写 / HTTP 语义（如 BAD_REQUEST），避免误判
  readability-identifier-naming.EnumConstantCase: UPPER_CASE
  readability-identifier-naming.FunctionCase: lower_case
  readability-identifier-naming.MethodCase: lower_case
  readability-identifier-naming.VariableCase: lower_case
  readability-identifier-naming.ParameterCase: lower_case
  readability-identifier-naming.MemberCase: lower_case
  # 允许末尾下划线成员（如 bus_handle_），避免与 LLVM 默认命名规则冲突
  readability-identifier-naming.MemberIgnoredRegexp: '.*_$'
  readability-identifier-naming.ConstantMemberCase: lower_case
  readability-identifier-naming.ConstantParameterCase: lower_case
  readability-identifier-naming.GlobalConstantCase: UPPER_CASE
  readability-identifier-naming.GlobalConstantPrefix: ''
  readability-identifier-naming.GlobalConstantIgnoredRegexp: '^(k.*|GDEY027T91_.*)'
  readability-identifier-naming.MacroDefinitionCase: UPPER_CASE
  readability-identifier-naming.TemplateParameterCase: CamelCase
  readability-identifier-naming.TypeAliasCase: CamelCase
  readability-identifier-naming.TypedefCase: CamelCase
  # ESP-IDF / C 头文件中大量 snake_case 别名（如 esp_event_base_t）
  readability-identifier-naming.TypedefIgnoredRegexp: '^esp_.*'
  readability-identifier-naming.IgnoreMainLikeFunctions: true

  # --- 其它 ---
  readability-non-const-parameter.StrictMode: false
  cppcoreguidelines-special-member-functions.AllowSoleDefaultDtor: true
